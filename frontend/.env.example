# Frontend service environment variables.
# `VITE_BACKEND_URL` overrides the dev-server proxy target. In docker-compose
# the default `http://backend:8000` works without changes; on the host you'd
# set this to `http://localhost:8000`.

VITE_BACKEND_URL=http://backend:8000

# Feature flags. Set to 1 (or true/yes/on) to enable.
#
# VITE_HIDE_PERSON_CLIPS — hides the "Person Clips" sidebar nav entry
# across every role. The route still serves; only the sidebar link +
# breadcrumb are suppressed.
VITE_HIDE_PERSON_CLIPS=0
