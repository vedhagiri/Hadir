{
  "title": "Maugood — Operations",
  "uid": "maugood-ops",
  "tags": ["maugood"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 0,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s",
  "timepicker": {},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "Capture rate per camera",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "fps"},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(maugood_capture_frames_total[1m])",
          "legendFormat": "tenant {{tenant}} / cam {{camera}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Identification rate (% events with employee_id)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (rate(maugood_detection_events_total{identified=\"true\"}[5m])) / clamp_min(sum by (tenant) (rate(maugood_detection_events_total[5m])), 1e-9)",
          "legendFormat": "tenant {{tenant}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Attendance records computed (per hour)",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (increase(maugood_attendance_records_computed_total[1h]))",
          "legendFormat": "tenant {{tenant}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Camera reachability matrix",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ]
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "maugood_camera_reachable",
          "legendFormat": "tenant {{tenant}} / cam {{camera}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Email delivery success rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (rate(maugood_email_send_total{status=\"sent\"}[15m])) / clamp_min(sum by (tenant) (rate(maugood_email_send_total{status=~\"sent|failed\"}[15m])), 1e-9)",
          "legendFormat": "tenant {{tenant}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active sessions",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "maugood_active_sessions",
          "legendFormat": "tenant {{tenant}}"
        }
      ]
    }
  ]
}
