# Backend service environment variables.
# In docker-compose these are sourced from the repo-root .env file; this file
# documents what the backend itself reads.

MAUGOOD_ENV=dev
MAUGOOD_TENANT_MODE=single

# Runtime (maugood_app) and migration (maugood_admin) connections. See
# backend/CLAUDE.md "Database roles and grants".
MAUGOOD_DATABASE_URL=postgresql+psycopg://maugood_app:maugood_app@postgres:5432/maugood
MAUGOOD_ADMIN_DATABASE_URL=postgresql+psycopg://maugood:maugood@postgres:5432/maugood

# Password values must match the embedded passwords in the URLs
# above (the bootstrap superuser uses MAUGOOD_ADMIN_DB_PASSWORD;
# a mismatch with the URL produces "password authentication failed
# for user 'maugood'" on first migration).
MAUGOOD_APP_DB_PASSWORD=maugood_app
MAUGOOD_ADMIN_DB_PASSWORD=maugood

MAUGOOD_SESSION_SECRET=change-me-please
MAUGOOD_FERNET_KEY=change-me-generate-with-cryptography
