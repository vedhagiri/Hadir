# Hadir — repo-root environment file.
# Copy to `.env` and fill in. docker-compose reads this; backend reads the
# same `HADIR_*` variables via pydantic-settings.

# App-runtime DB URL (hadir_app role — limited grants, audit_log is
# append-only from this connection).
HADIR_DATABASE_URL=postgresql+psycopg://hadir_app:hadir_app@postgres:5432/hadir

# Admin DB URL (hadir_admin role) — used by Alembic migrations and
# backend/scripts/seed_admin.py. NEVER used at request time.
HADIR_ADMIN_DATABASE_URL=postgresql+psycopg://hadir:hadir@postgres:5432/hadir

# Passwords the initial migration uses to CREATE/ALTER the two DB roles.
# Change these before first-run in any shared environment.
HADIR_APP_DB_PASSWORD=hadir_app
HADIR_ADMIN_DB_PASSWORD=hadir_admin

# Secrets
HADIR_SESSION_SECRET=change-me-please
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HADIR_FERNET_KEY=change-me-generate-with-cryptography
# v1.0 P6: separate Fernet key for auth-scoped secrets (Entra OIDC client
# secret, future SAML metadata). Keep distinct from HADIR_FERNET_KEY so a
# leak of one doesn't compromise the other.
HADIR_AUTH_FERNET_KEY=change-me-generate-with-cryptography
# Base URL Entra ID redirects back to (the redirect URI is
# {HADIR_OIDC_REDIRECT_BASE_URL}/api/auth/oidc/callback). Production
# must be HTTPS.
HADIR_OIDC_REDIRECT_BASE_URL=http://localhost:8000

HADIR_TENANT_MODE=single
HADIR_ENV=dev
