# Maugood — repo-root environment file.
# Copy to `.env` and fill in. docker-compose reads this; backend reads the
# same `MAUGOOD_*` variables via pydantic-settings.

# App-runtime DB URL (maugood_app role — limited grants, audit_log is
# append-only from this connection).
MAUGOOD_DATABASE_URL=postgresql+psycopg://maugood_app:maugood_app@postgres:5432/maugood

# Admin DB URL (maugood_admin role) — used by Alembic migrations and
# backend/scripts/seed_admin.py. NEVER used at request time.
MAUGOOD_ADMIN_DATABASE_URL=postgresql+psycopg://maugood:maugood@postgres:5432/maugood

# Passwords the initial migration uses to CREATE/ALTER the two DB roles.
# Change these before first-run in any shared environment.
MAUGOOD_APP_DB_PASSWORD=maugood_app
MAUGOOD_ADMIN_DB_PASSWORD=maugood_admin

# Secrets
MAUGOOD_SESSION_SECRET=change-me-please
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAUGOOD_FERNET_KEY=change-me-generate-with-cryptography
# v1.0 P6: separate Fernet key for auth-scoped secrets (Entra OIDC client
# secret, future SAML metadata). Keep distinct from MAUGOOD_FERNET_KEY so a
# leak of one doesn't compromise the other.
MAUGOOD_AUTH_FERNET_KEY=change-me-generate-with-cryptography
# Base URL Entra ID redirects back to (the redirect URI is
# {MAUGOOD_OIDC_REDIRECT_BASE_URL}/api/auth/oidc/callback). Production
# must be HTTPS.
MAUGOOD_OIDC_REDIRECT_BASE_URL=http://localhost:8000

MAUGOOD_TENANT_MODE=single
MAUGOOD_ENV=dev

# --- Production hardening (v1.0 P23) -----------------------------------
# Set ``MAUGOOD_ENV=production`` only after every variable below is
# filled in for the target environment — the backend refuses to
# boot with MAUGOOD_ENV=production unless these are set, and an
# operator-facing error message points at the specific failure.
#
# Comma-separated origins the API accepts CORS preflights from.
# Empty in dev. In production set to your public origin (e.g.
# ``https://maugood.example.com``); nginx serves the frontend on
# the same origin so this is effectively a tightening guardrail.
MAUGOOD_ALLOWED_ORIGINS=

# Mark the FastAPI process as living behind a reverse proxy that
# strips/rewrites X-Forwarded-Proto and X-Forwarded-For. Required
# in production — the HTTPS gate trusts request.url.scheme which
# Starlette resolves from these headers via ProxyHeadersMiddleware.
MAUGOOD_BEHIND_PROXY=false

# Trusted hop allowlist for ProxyHeadersMiddleware. ``*`` means
# "trust forwarded headers from any peer" — fine when the backend
# port is only reachable inside a private docker network. Tighten
# to nginx's IP if you ever expose the backend port directly.
MAUGOOD_FORWARDED_ALLOW_IPS=*

# Send Strict-Transport-Security with a 1-year max-age by default.
# nginx ships HSTS too; the backend's copy is defence in depth so
# the API stays safe even if a future deployment swaps proxies.
MAUGOOD_HSTS_MAX_AGE_SECONDS=31536000

# Flip to ``true`` in production. The backend refuses to boot
# without it under MAUGOOD_ENV=production.
MAUGOOD_SESSION_COOKIE_SECURE=false

# Optional dual-cert layout for the nginx service. See
# docs/deploy-production.md "TLS cert handling" for the choice
# between operator-provided certs (default) and Let's Encrypt.
# Paths are relative to the host (mounted into the nginx container
# at ``/etc/nginx/certs``).
MAUGOOD_TLS_CERT_PATH=./ops/certs/fullchain.pem
MAUGOOD_TLS_KEY_PATH=./ops/certs/privkey.pem
# Public hostname the frontend + API are served on. nginx uses it
# in its server_name directive and in the redirect from :80.
MAUGOOD_PUBLIC_HOSTNAME=maugood.local
